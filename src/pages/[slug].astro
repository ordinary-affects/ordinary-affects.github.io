---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';

export async function getStaticPaths() {
  const vignettes = (await getCollection('vignettes')).sort((a, b) => {
    const byDate = b.data.updated.getTime() - a.data.updated.getTime();
    return byDate !== 0 ? byDate : a.data.title.localeCompare(b.data.title);
  });
  return vignettes.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: vignettes[i - 1] ?? null,
      next: vignettes[i + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---
<Base title={entry.data.title}>
  <article class="vignette">
    <h1 class="vtitle">{entry.data.title}</h1>
    <div class="vbody"><Content /></div>
  </article>
  <nav class="vnav">
    {prev ? <a href={`/${prev.id}/`}>← {prev.data.title}</a> : <span />}
    <a class="mid" href="/">index</a>
    {next ? <a href={`/${next.id}/`}>{next.data.title} →</a> : <span />}
  </nav>
</Base>
